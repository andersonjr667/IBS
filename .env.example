# ==================== CONFIGURAÇÕES DO SERVIDOR ====================

# Ambiente (development, production, testing)
NODE_ENV=development

# Porta do servidor
PORT=3000

# ==================== BANCO DE DADOS ====================

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ibs
# Para MongoDB Atlas (nuvem):
# MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/ibs

# ==================== CORS ====================
CORS_ORIGIN=*

# ==================== JWT (JSON Web Tokens) ====================

# Chave secreta para assinar JWT
JWT_SECRET=sua_chave_secreta_super_segura_aqui_2026
JWT_EXPIRE=7d

# ==================== EMAIL ====================

# SMTP (Gmail, OutLook, etc)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_app

# Email padrão da instituição
ADMIN_EMAIL=contato@ibs.com.br
ADMIN_NAME=Igreja Batista Solidária

# ==================== PAGAMENTOS ====================

# Stripe
STRIPE_PUBLIC_KEY=pk_test_sua_chave_publica
STRIPE_SECRET_KEY=sk_test_sua_chave_secreta

# PayPal
PAYPAL_CLIENT_ID=seu_client_id
PAYPAL_CLIENT_SECRET=seu_client_secret
PAYPAL_MODE=sandbox

# ==================== INTEGRAÇÕES ====================

# Google Analytics
GOOGLE_ANALYTICS_ID=GA_XXXXXXXXX

# Envio de SMS (Twilio - opcional)
TWILIO_ACCOUNT_SID=seu_account_sid
TWILIO_AUTH_TOKEN=seu_auth_token
TWILIO_PHONE=+5531999999999

# ==================== INFORMAÇÕES DA INSTITUIÇÃO ====================

# Nome
CHURCH_NAME=Igreja Batista Solidária
CHURCH_ABBREVIATION=IBS

# Contato
CHURCH_EMAIL=contato@ibs.com.br
CHURCH_PHONE=+55 31 3041-0000
CHURCH_WHATSAPP=+55 31 98410-0000

# Endereço
CHURCH_ADDRESS=Rua Aiuruoca, 125
CHURCH_CITY=Belo Horizonte
CHURCH_STATE=MG
CHURCH_ZIP=31910-130

# Redes Sociais
INSTAGRAM=igrejabatistasolidaria
FACEBOOK=Igreja-Batista-Solidaria
YOUTUBE=igrejabatistasolidaria

# ==================== CONFIGURAÇÕES DE DESENVOLVIMENTO ====================

# Debug mode
DEBUG=true

# Logs
LOG_LEVEL=info

# Segurança
API_KEY=sua_chave_api_aqui
ALLOW_REGISTRATION=true

# ==================== URLS ====================

# Frontend URL
FRONTEND_URL=http://localhost:3000
FRONTEND_PROD_URL=https://igrejabatistasolidaria.com.br

# Backend URL
BACKEND_URL=http://localhost:3001
BACKEND_PROD_URL=https://api.igrejabatistasolidaria.com.br
