# ==================== CONFIGURAÇÃO DO AMBIENTE ====================

# Ambiente
NODE_ENV=development
PORT=3000

# ==================== MONGODB ====================
# Se você está usando MongoDB localmente (recomendado para desenvolvimento)
MONGODB_URI=mongodb://localhost:27017/ibs

# Se você está usando MongoDB Atlas (nuvem), descomente e configure:
# MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/ibs?retryWrites=true&w=majority

# ==================== AUTENTICAÇÃO ====================
JWT_SECRET=sua_chave_secreta_muito_segura_aqui_123456789
JWT_EXPIRE=7d

# ==================== CORS ====================
CORS_ORIGIN=http://localhost:3000

# ==================== EMAIL (SMTP - Opcional) ====================
# Configure para enviar notificações por email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_ou_app_password

# ==================== NOTIFICAÇÕES ====================
# Enviar emails de confirmação?
SEND_VERIFICATION_EMAIL=false

# ==================== LOGGING ====================
# Nível de log: debug, info, warn, error
LOG_LEVEL=debug
